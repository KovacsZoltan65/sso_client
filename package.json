{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "e2e:auth": "node tests/e2e/scripts/prepare-auth-e2e.mjs && playwright test tests/e2e/auth-flow.spec.ts",
        "e2e:auth:headed": "node tests/e2e/scripts/prepare-auth-e2e.mjs && playwright test tests/e2e/auth-flow.spec.ts --headed",
        "e2e:auth:prepare": "node tests/e2e/scripts/prepare-auth-e2e.mjs",
        "test": "vitest run",
        "test:security": "vitest run --config vitest.security.config.js",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@inertiajs/vue3": "^2.0.0",
        "@playwright/test": "^1.54.2",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/test-utils": "^2.4.6",
        "autoprefixer": "^10.4.12",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "jsdom": "^29.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.2.1",
        "vite": "^7.0.7",
        "vitest": "^4.1.2",
        "vue": "^3.4.0"
    },
    "dependencies": {
        "@primeuix/themes": "^2.0.3",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.4"
    }
}
